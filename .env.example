# Shared
NODE_ENV=development
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# API Gateway
API_GATEWAY_PORT=3000
AUTH_SERVICE_URL=http://auth-service:3001
EVENT_SERVICE_URL=http://event-service:3002
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Auth Service
AUTH_SERVICE_PORT=3001
AUTH_DB_HOST=postgres-auth
AUTH_DB_PORT=5432
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_pass
BCRYPT_ROUNDS=12

# Event Service
EVENT_SERVICE_PORT=3002
EVENT_DB_HOST=postgres-event
EVENT_DB_PORT=5432
EVENT_DB_NAME=event_db
EVENT_DB_USER=event_user
EVENT_DB_PASSWORD=event_pass

# Kafka / Redis
KAFKA_BROKER=kafka:9092
REDIS_URL=redis://redis:6379
ACCOUNTS_SERVICE_URL=http://accounts-service:3003
TRANSACTION_SERVICE_URL=http://transaction-service:3004
DEFAULT_TIMEOUT=5000
