{
  "name": "event-service",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:generate": "typeorm-ts-node-commonjs migration:generate ./src/migrations/AutoMigration -d ./src/db/data-source.ts",
    "db:migrate": "typeorm-ts-node-commonjs migration:run -d ./src/db/data-source.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "kafkajs": "^2.2.4",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "pino-http": "^10.1.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "ts-node": "^10.9.2",
    "tsx": "^4.16.2",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.5.4"
  }
}
